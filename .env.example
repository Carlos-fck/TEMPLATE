ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/template_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
SECRET_KEY=change-me

# --- Compose / deploy ---
# Image tag used by docker-compose (Coolify can override IMAGE_TAG).
IMAGE_NAME=template
IMAGE_TAG=latest
# Public host port for the app service. On Coolify, leave 8000 — the panel
# handles the public proxy (Traefik); only the container port matters.
APP_PORT=8000
# Number of Celery worker processes per container.
CELERY_CONCURRENCY=1
# Compose project name (groups containers in `docker ps`).
COMPOSE_PROJECT_NAME=template

# --- Postgres bootstrap (for the bundled `db` service) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Auth (demo) ---
SESSION_COOKIE=template_session
SESSION_MAX_AGE=28800
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- Branding ---
BRAND_NAME=TEMPLATE
BRAND_SHORT=T
BRAND_LOGO_URL=
BRAND_TAGLINE=Production-ready boilerplate

# --- Theme (any valid CSS color) ---
THEME_PRIMARY=#2563eb
THEME_PRIMARY_CONTRAST=#ffffff
THEME_SECONDARY=#64748b
THEME_ACCENT=#10b981
THEME_BG=#f8fafc
THEME_SURFACE=#ffffff
THEME_TEXT=#0f172a
THEME_TEXT_MUTED=#64748b
THEME_BORDER=#e2e8f0
THEME_SIDEBAR_BG=#0f172a
THEME_SIDEBAR_TEXT=#e2e8f0
THEME_SIDEBAR_ACTIVE=#1e293b
THEME_DANGER=#ef4444
THEME_SUCCESS=#22c55e
THEME_WARNING=#f59e0b
THEME_RADIUS=8px
THEME_FONT=system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif
