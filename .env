ENV=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/template_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
SECRET_KEY=change-me

# Port and compose settings (parameterize host port mappings)
APP_PORT=8000
REDIS_PORT=6379
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=template_db
COMPOSE_PROJECT_NAME=template
